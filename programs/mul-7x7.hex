# 7 x 7 = 49 by repeated addition
# Result lands in $0102 (= $31 = 49 decimal)

# Setup ----------------------------------------
86 07           # LDAA #$07
B7 01 00        # STAA $0100   (the addend)
B7 01 01        # STAA $0101   (the counter)
4F              # CLRA         (running total = 0)

# Loop ----------------------------------------- (this is $0009)
BB 01 00        # ADDA $0100   A += addend
7A 01 01        # DEC  $0101   counter -= 1
26 F8           # BNE  -8      if counter != 0, back to loop

# Done -----------------------------------------
B7 01 02        # STAA $0102   store result
3E              # WAI          halt
